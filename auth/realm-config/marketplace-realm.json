{
    "realm": "marketplace",
    "enabled": true,
    "displayName": "Marketplace",
    "sslRequired": "external",
    "registrationAllowed": true,
    "loginWithEmailAllowed": true,
    "duplicateEmailsAllowed": false,
    "resetPasswordAllowed": true,
    "editUsernameAllowed": false,
    "bruteForceProtected": true,
    "permanentLockout": false,
    "maxFailureWaitSeconds": 900,
    "minimumQuickLoginWaitSeconds": 60,
    "waitIncrementSeconds": 60,
    "quickLoginCheckMilliSeconds": 1000,
    "maxDeltaTimeSeconds": 43200,
    "failureFactor": 5,
    "roles": {
        "realm": [
            {
                "name": "buyer",
                "description": "Acheteur - peut consulter et acheter des articles"
            },
            {
                "name": "seller",
                "description": "Vendeur - peut publier et gérer ses articles"
            },
            {
                "name": "admin",
                "description": "Administrateur - accès complet"
            }
        ]
    },
    "clients": [
        {
            "clientId": "marketplace-app",
            "name": "Marketplace Application",
            "enabled": true,
            "publicClient": true,
            "directAccessGrantsEnabled": true,
            "standardFlowEnabled": true,
            "implicitFlowEnabled": false,
            "redirectUris": [
                "http://localhost:3000/*",
                "https://marketplace.local/*"
            ],
            "webOrigins": [
                "http://localhost:3000",
                "https://marketplace.local"
            ],
            "defaultClientScopes": [
                "web-origins",
                "profile",
                "roles",
                "email"
            ],
            "protocolMappers": [
                {
                    "name": "realm-roles",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-usermodel-realm-role-mapper",
                    "config": {
                        "claim.name": "realm_access.roles",
                        "jsonType.label": "String",
                        "multivalued": "true",
                        "id.token.claim": "true",
                        "access.token.claim": "true",
                        "userinfo.token.claim": "true"
                    }
                }
            ]
        },
        {
            "clientId": "marketplace-backend",
            "name": "Marketplace Backend",
            "enabled": true,
            "publicClient": false,
            "bearerOnly": true,
            "standardFlowEnabled": false
        }
    ],
    "defaultDefaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
    ],
    "users": [
        {
            "username": "admin",
            "enabled": true,
            "emailVerified": true,
            "email": "admin@marketplace.local",
            "firstName": "Admin",
            "lastName": "User",
            "credentials": [
                {
                    "type": "password",
                    "value": "admin123",
                    "temporary": false
                }
            ],
            "realmRoles": [
                "admin"
            ]
        },
        {
            "username": "seller1",
            "enabled": true,
            "emailVerified": true,
            "email": "seller1@marketplace.local",
            "firstName": "Jean",
            "lastName": "Vendeur",
            "credentials": [
                {
                    "type": "password",
                    "value": "seller123",
                    "temporary": false
                }
            ],
            "realmRoles": [
                "seller"
            ]
        },
        {
            "username": "buyer1",
            "enabled": true,
            "emailVerified": true,
            "email": "buyer1@marketplace.local",
            "firstName": "Marie",
            "lastName": "Acheteuse",
            "credentials": [
                {
                    "type": "password",
                    "value": "buyer123",
                    "temporary": false
                }
            ],
            "realmRoles": [
                "buyer"
            ]
        }
    ]
}
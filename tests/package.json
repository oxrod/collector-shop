{
  "name": "marketplace-e2e-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --runInBand --timeout=30000",
    "test:e2e": "jest --runInBand --timeout=30000",
    "siege:baseline": "siege --rc=siege/siege.conf -c 25 -t 60S -f siege/urls-public.txt",
    "siege:load": "siege --rc=siege/siege.conf -c 100 -t 120S -f siege/urls-public.txt",
    "siege:stress": "siege --rc=siege/siege.conf -c 250 -t 60S -f siege/urls-stress.txt",
    "siege:all": "bash siege/run-load-tests.sh"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "axios": "^1.6.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "rootDir": ".",
    "testMatch": ["<rootDir>/e2e/**/*.test.ts"],
    "moduleFileExtensions": ["ts", "js", "json"]
  }
}

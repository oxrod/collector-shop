{
    "name": "marketplace-notification-service",
    "version": "1.0.0",
    "description": "Notification microservice (email, push)",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/main.js",
        "dev": "ts-node-dev --respawn src/main.ts",
        "test": "jest",
        "test:cov": "jest --coverage"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "express-rate-limit": "^7.5.1",
        "helmet": "^7.1.0",
        "nodemailer": "^6.9.8",
        "prom-client": "^15.1.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.11",
        "@types/node": "^20.11.5",
        "@types/nodemailer": "^6.4.14",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "collectCoverageFrom": ["src/**/*.ts"],
        "coverageThreshold": {
            "global": {
                "branches": 70,
                "functions": 70,
                "lines": 80,
                "statements": 80
            }
        }
    }
}

# Example environment file for Vite.
# Copy to `.env` for local development.
#
# These variables are embedded at build time (VITE_*).

VITE_API_URL=/api

# Keycloak (with ingress: usually same origin + /auth; override for local Keycloak)
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=marketplace
VITE_KEYCLOAK_CLIENT_ID=marketplace-app

